# Santa iOS Enterprise Framework - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# DEVICE CONFIGURATION
# ============================================================================

# Device UDID (get via: xcrun simctl list devices)
DEVICE_UDID_0=00008101-000541A91234C0AC
DEVICE_UDID_1=00008101-000541A91234C0AD  # Optional: Second device for parallel testing

# ============================================================================
# APPIUM SERVER CONFIGURATION
# ============================================================================

# Appium server host
APPIUM_HOST=127.0.0.1

# Appium server port
APPIUM_PORT=4723

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Bundle ID for the app under test
BUNDLE_ID=com.brave.ios

# App locale (language and region)
LOCALE=en_US

# App timezone
TIMEZONE=America/Los_Angeles

# ============================================================================
# APPIUM/XCTEST CONFIGURATION
# ============================================================================

# Appium command timeout (seconds)
COMMAND_TIMEOUT=60

# Show Appium server logs (true/false)
SHOW_LOGS=true

# Use real device or simulator (real/simulator)
DEVICE_TYPE=simulator

# ============================================================================
# TEST EXECUTION CONFIGURATION
# ============================================================================

# Implicit wait timeout (seconds)
IMPLICIT_WAIT=10

# Explicit wait timeout (seconds)
EXPLICIT_WAIT=15

# Page load timeout (seconds)
PAGE_LOAD_TIMEOUT=30

# Test timeout (seconds)
TEST_TIMEOUT=300

# ============================================================================
# REPORTING CONFIGURATION
# ============================================================================

# Report output directory
REPORTS_PATH=reports

# Generate HTML report (true/false)
GENERATE_HTML_REPORT=true

# Screenshot on failure (true/false)
SCREENSHOT_ON_FAILURE=true

# Capture logs (true/false)
CAPTURE_LOGS=true

# ============================================================================
# ANALYTICS CONFIGURATION
# ============================================================================

# Mitmproxy port for analytics capture (optional)
MITMPROXY_PORT=8080

# Capture analytics events (true/false)
CAPTURE_ANALYTICS=true

# Analytics output file
ANALYTICS_OUTPUT=analytics_events.xlsx

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=reports/logs/test.log

# Console log output (true/false)
CONSOLE_LOG=true

# ============================================================================
# CI/CD CONFIGURATION (if using Jenkins or GitHub Actions)
# ============================================================================

# CI/CD system type (local/jenkins/github/azure)
CI_SYSTEM=local

# Parallel test workers
PARALLEL_WORKERS=2

# Enable parallel execution (true/false)
PARALLEL_EXECUTION=true

# ============================================================================
# DEBUG CONFIGURATION
# ============================================================================

# Enable debug mode (true/false)
DEBUG_MODE=false

# Appium debug level
APPIUM_DEBUG_LEVEL=info

# Slow down execution (milliseconds between actions)
SLOW_MOTION=0
